# Beacon node (consensus-layer) REST endpoint + bearer token.
# Copy to `.env` and fill in. The backend auto-loads `.env` via python-dotenv.
#
# Historical backfill to Pectra requires an ARCHIVE beacon node (one that serves
# finalized state for past slots). A standard pruned node only answers recent slots.
BEACON_URL=https://your-beacon-node.example/
BEACON_TOKEN=your_bearer_token_here
